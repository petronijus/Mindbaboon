EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-app-password
DEFAULT_TO_ADDRESS=your-email@example.com

# Public hostname used in reminder email links + OAuth redirect URI.
# Set to your prod FQDN (e.g. mindbaboon.example.com) — scheduler._base_url()
# auto-switches between HTTPS-no-port and HTTP:5000 based on this.
SERVER_HOST=mindbaboon.example.com

# X-API-Key for REST/MCP (independent of Google login).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MINDBABOON_API_KEY=generate-a-long-random-string

# Flask session cookie signing key.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=generate-a-long-random-string

# Google OAuth 2.0 Web Application client (create in Google Cloud Console).
# Authorized redirect URI: https://<SERVER_HOST>/oauth2/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Comma-separated lowercase emails allowed to log in.
ALLOWED_EMAILS=
